SCRYFALL_USER_AGENT=ScryfallMCPServer/1.0.2
RATE_LIMIT_MS=100
LOG_LEVEL=info
NODE_ENV=development
SCRYFALL_TIMEOUT_MS=15000
HEALTHCHECK_DEEP=false
RATE_LIMIT_QUEUE_MAX=500
CACHE_MAX_SIZE=10000
CACHE_MAX_MEMORY_MB=100
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_MCP_PATH=/mcp
HTTP_HEALTH_PATH=/health
# Optional comma-separated allowlist for browser-style Origin headers.
# Leave unset to allow only loopback origins by default.
HTTP_ALLOWED_ORIGINS=
